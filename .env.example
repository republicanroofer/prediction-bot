# ── Mode ─────────────────────────────────────────────────────────────────────
TRADING_MODE=paper                  # paper | live
ACTIVE_EXCHANGE=both                # kalshi | polymarket | both

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://prediction_bot:prediction_bot@localhost:5432/prediction_bot

# ── Kalshi ────────────────────────────────────────────────────────────────────
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem
# Alternative: paste PEM content inline (use \n for newlines):
# KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE....\n-----END RSA PRIVATE KEY-----"

# ── Polymarket ────────────────────────────────────────────────────────────────
POLYGON_WALLET_PRIVATE_KEY=         # 0x-prefixed hex private key
POLYGON_RPC_URL=https://polygon-rpc.com

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
DAILY_LLM_BUDGET_USD=10.0

# ── News ──────────────────────────────────────────────────────────────────────
NEWSAPI_KEY=

# ── Telegram ──────────────────────────────────────────────────────────────────
# Setup instructions:
#   1. Message @BotFather on Telegram → /newbot → follow prompts → get token
#   2. Add the bot to a chat or channel where you want alerts
#   3. Get your chat_id: message the bot, then visit
#      https://api.telegram.org/bot<TOKEN>/getUpdates → look for "chat":{"id":...}
#   4. For error alerts, create a second chat/channel and get that chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ERROR_CHAT_ID=

# ── Position sizing ───────────────────────────────────────────────────────────
KELLY_FRACTION=0.25
MAX_POSITION_PCT=0.03
MAX_SECTOR_CONCENTRATION_PCT=0.30

# ── Whale mirroring ───────────────────────────────────────────────────────────
WHALE_MIRROR_DELAY_S=45
WHALE_MIN_TRADE_USD=500.0
WHALE_MIN_SCORE=60.0

# ── Risk ──────────────────────────────────────────────────────────────────────
STOP_LOSS_PCT=0.40
TAKE_PROFIT_PCT=0.80
MAX_DRAWDOWN_PCT=0.20
MAX_HOLD_HOURS=240
